{
  "version": 3,
  "faceit": {
    "baseUrlV3": "https://www.faceit.com/api/stats/v3",
    "baseUrlV4": "https://open.faceit.com/data/v4",
    "useProxy": false,
    "proxyBaseUrl": null
  },
  "apiQueue": {
    "rps": 10,
    "metrics": {
      "enabled": true,
      "intervalMs": 60000
    }
  },
  "cdn": {
    "paths": {
      "mapsConfig": "/config/mappool.json",
      "selectorsConfig": "/config/selectors.json",
      "endpointsConfig": "/config/endpoints.json",
      "mapIcon": "/web/images/maps/48"
    }
  }
}
